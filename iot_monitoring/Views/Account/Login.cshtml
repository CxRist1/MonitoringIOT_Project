@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Login - IoT Monitoring</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" />

    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>

<body>

    <div class="container">

        <div class="row justify-content-center">

            <div class="col-md-5">

                <div class="card shadow-lg">

                    <div class="card-body">

                        <h2 class="text-center fw-bold text-primary">
                            IoT Monitoring
                        </h2>

                        <p class="text-center text-muted">
                            Smart Monitoring Platform
                        </p>

                        <hr />

                        <form>

                            <!-- Username -->

                            <div class="mb-3">

                                <label class="form-label fw-bold">
                                    Username
                                </label>

                                <input type="text"
                                       class="form-control"
                                       placeholder="Enter username">

                            </div>

                            <!-- Password -->

                            <div class="mb-3">

                                <label class="form-label fw-bold">
                                    Password
                                </label>

                                <input type="password"
                                       class="form-control"
                                       id="passwordInput"
                                       placeholder="Enter password">

                            </div>

                            <div class="form-check mb-3">

                                <input class="form-check-input"
                                       type="checkbox"
                                       id="remember">

                                <label class="form-check-label"
                                       for="remember">

                                    Remember Me

                                </label>

                            </div>

                            <div class="d-grid">

                                <button type="submit"
                                        class="btn btn-primary">

                                    Login

                                </button>

                            </div>

                        </form>

                        <div class=" mt-4">

                            <a href="#" class=" justify-content-center">
                                Forgot Password?
                            </a><br />

                            <small class="text-muted justify-content-end">

                                Version 1.0

                            </small><br />

                            <small class="text-muted justify-content-end">
                                Developed by Suphawat
                            </small>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>
    <script src="~/js/Login.js" asp-append-version="true"></script>

</body>
</html>