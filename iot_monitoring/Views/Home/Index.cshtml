@{
    ViewData["Title"] = "Home Page";
    Layout = null;
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Iot Shop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-white mb-0">
        <div class="container-fluid justify-content-end">
            <a href="/Account/Login" class="btn btn-primary me-2" type="button">Sign In</a>
        </div>
    </nav>
    <div class="container-fluid mb-3 mt-0">
        <div class="card">
            <div class="card-body d-flex">
                <h1 class="fw-bold mb-0">IOT SHOP</h1>
                <div class="ms-3 mt-1">
                    <h3>
                        <a asp-controller="Account"
                           asp-action="Login">
                            การติดต่อ
                       </a>
                    </h3>
                </div>

                <div class="ms-3 mt-1">
                    <h3>สินค้า</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid">
        <div class="row gx-2">
            <div class="col-md-2 mb-3">
                <ul class="nav flex-column nav-pills">
                    <li class="nav-item">
                        <a class="nav-link active" href="#">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Product</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Promotion</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Photo Gallery</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Contact Us</a>
                    </li>
                </ul>
            </div>
            <div class="col">
                <div class="card w-100" style="min-height :200px;min-width:200px">
                    <div class="card-body">
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>