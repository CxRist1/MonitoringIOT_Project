    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Dashboard";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/dashboard.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-dark bg-primary">
        <div class="container-fluid">
            <span class="navbar-brand mb-0 h1">
                Iot Monitorin Dashboard
            </span>
            <a asp-controller="Devices"
               asp-action="Index"
               class="btn btn-outline-primary bg-white mt-2">
                Back to Devices Page
            </a>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="col-md-10 p-4">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold">
                        Dashboard
                    </h2>
                    <p class="text-muted mb-0">Realtime sensor monitoring overview</p>
                </div>
                <span class="badge bg-success">
                    Online
                </span>
            </div>

            <div class="row g-3">
                <div class="col-md-3">
                    <div class="card sensor-card">
                        <div class="card-body">
                            <h6 class="text-muted"> Temperature </h6>
                            <h3 class="fw-bold" id="temperatureValue">-- °C</h3>
                            <small class="text-success">Normal</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card sensor-card">
                        <div class="card-body">
                            <h6 class="text-muted"> Humidity </h6>
                            <h3 class="fw-bold " id="humidityValue">-- %</h3>
                            <small class="text-success">Normal</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card sensor-card">
                        <div class="card-body">
                            <h6 class="text-muted"> Soil Moisture </h6>
                            <h3 class="fw-bold " id="soilValue">-- %</h3>
                            <small class="text-success">Low</small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card sensor-card">
                        <div class="card-body">
                            <h6 class="text-muted"> Device Status </h6>
                            <h3 class="fw-bold " id="statusValue">--</h3>
                            <small class="text-success">Normal</small>
                        </div>

                    </div>
                </div>
            </div>

            <div class="card chart-card mt-4">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">
                        Sensor Trend
                    </h5>
                    <canvas id="sensorChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
</body>
</html>

