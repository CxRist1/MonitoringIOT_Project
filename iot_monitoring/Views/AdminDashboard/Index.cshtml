@model iot_monitoring.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "admin dashboard";
}

<div class="container py-4">
    <div class="mb-4">
        <h2 class="mb-1">Admin Dashboard</h2>
        <p class="text-muted mb-0">
            Overview of store performance
        </p>
    </div>
    <div class="row g-4">
        <div class="col-12 col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-2">
                        Today's Revenue
                    </p>

                    <h3 class="mb-0">
                        ฿@Model.TodayRevenue.ToString("N2")
                    </h3>

                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-2">
                        Today's Orders
                    </p>

                    <h3 class="mb-0">
                        @Model.TodayOrders
                    </h3>

                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-2">
                        Pending Orders
                    </p>

                    <h3 class="mb-0">
                        @Model.PendingOrders
                    </h3>

                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-2">
                        Completed Orders
                    </p>

                    <h3 class="mb-0">
                        @Model.CompletedOrders
                    </h3>

                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-2">
                        Total Users
                    </p>

                    <h3 class="mb-0">
                        @Model.TotalUsers
                    </h3>

                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <p class="text-muted mb-2">
                        Total Products
                    </p>

                    <h3 class="mb-0">
                        @Model.TotalProducts
                    </h3>

                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0">Revenue (Last 7 Days)</h5>
                    </div>

                    <div class="card-body">
                        <div style="position: relative; height: 350px;">
                            <canvas id="revenueChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const revenueChartLabels = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(Model.RevenueLabels)
                    );

        const revenueChartData = @Html.Raw(
                    System.Text.Json.JsonSerializer.Serialize(Model.RevenueData)
                    );

        const revenueChartElement =
            document.getElementById("revenueChart");

        if (revenueChartElement) {
            new Chart(revenueChartElement, {
                type: "line",
                data: {
                    labels: revenueChartLabels,
                    datasets: [
                        {
                            label: "Revenue",
                            data: revenueChartData,
                            borderWidth: 2,
                            tension: 0.3,
                            fill: false
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        y: {
                            beginAtZero: true
                        }
                    }
                }
            });
        }
    </script>

}