@model List<iot_monitoring.Models.Device>
@{
    ViewData["Title"] = "Devices Center";
}

<div class="container met-4">
    <div>
        <h2 class="fw-bold md-1">Device Center</h2>
        <p class=" text-muted mb-0">Select a device to viewmonitoring dashboard</p>
    </div>

    <button type ="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target = "#addDeviceModal">
        + Add Device
    </button>
</div>

<div class="row">
    @foreach (var device in Model)
    {
        <div class="col-lg-6 col-md-6 col-sm-12 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-lg-start mb-3">
                        <div>
                            <h5 class="card-title fw-bold mb-1">
                                @device.DeviceName
                            </h5>
                            <small class=" text-muted">
                                Device ID:@device.Id
                            </small>
                        </div>
                        @if (device.IsConnected)
                        {
                            <span class="badge bg-success">Online</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Offline</span>
                        }
                    </div>
                    <hr />
                    <p class="mb-2">
                        <strong>Status : </strong>
                        @(device.IsConnected ? "Ready for monitoring" : "Device is offline")
                    </p>
                    <div class="d-flex gap-2">
                        <a asp-controller="Dashboard"
                           asp-action="Index"
                           asp-route-deviceId="@device.Id"
                           class="btn btn-primary">
                            Dashboard
                        </a>

                        <a asp-controller="Devices"
                           asp-action="Edit"
                           asp-route-id="@device.Id"
                           class="btn btn-warning btn-sm text-center">
                            Edit
                        </a>

                        <form asp-controller="Devices"
                              asp-action="Delete"
                              asp-route-id="@device.Id"
                              method="post"
                              class="d-inline">
                            <button type="submit"
                                    class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Delecte this device')">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>

            </div>

        </div>
    }
</div>

<div class="modal fade" id="addDeviceModal" tabindex="-1" aria-labelledby="addDeviceModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">

            <form asp-controller="Devices" asp-action="Create" method="post">

                <div class="modal-header">
                    <h5 class="modal-title" id="addDeviceModalLabel">Add Device</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">

                    <div class="mb-3">
                        <label class="form-label">Device Name</label>
                        <input name="DeviceName" class="form-control" placeholder="ESP32 Room A" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input name="Location" class="form-control" placeholder="Lab Room" />
                    </div>

                    <div class="form-check">
                        <input name="IsConnected" class="form-check-input" type="checkbox" value="true" checked />
                        <label class="form-check-label">
                            Online
                        </label>
                    </div>

                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit" class="btn btn-primary">
                        Save Device
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>